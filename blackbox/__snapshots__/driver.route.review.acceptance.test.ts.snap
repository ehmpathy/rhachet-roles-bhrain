exports[`driver.route.review.acceptance given: [case1] route with single stone artifact when: [t0] route.review is invoked for stone 1 then: stdout matches snapshot 1`] = `
"🦉 look for the light

🗿 route.review
   ├─ the path leads here
   │  ├─ route = .
   │  └─ stone = 1
