exports[`driver.route.guard-upgrade.acceptance given: [case12] an upgrade whose stone is already passed (N6 note) when: [t0] plan --stone 5.1.execution then: stdout matches snapshot 1`] = `
"
рџ¦‰ the way reveals itself, one stone at a time

рџ—ї route.guard.upgrade --mode plan
   в”њв”Ђ route = route
   в”‚
   в”њв”Ђ 5.1.execution.guard
   в”‚  в”њв”Ђ decision = upgrade available
   в”‚  в”њв”Ђ from = templates/5.1.execution.guard
   в”‚  в”њв”Ђ вљ  stone 5.1.execution already passed under the prior guard вЂ” this upgrade re-syncs its rules but does not re-validate the passage
   в”‚  в””в”Ђ diff
   в”‚     в”њв”Ђ
   в”‚     в”‚
   в”‚     в”‚  -   - echo "reason: old frame"
   в”‚     в”‚  +   - echo "reason: new frame"
   в”‚     в”‚
   в”‚     в””в”Ђ
   в”‚
   в”њв”Ђ summary = 1 available
   в””в”Ђ to apply: rhx route.guard.upgrade --mode apply
"
`;

