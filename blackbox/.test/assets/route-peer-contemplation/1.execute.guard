artifacts:
  - 1.execute*.md

reviews:
  peer:
    - slug: architect
      budget: 3
      level: 1
      run: bash $route/.test/mock-review-blocker.sh
    - slug: mechanic
      budget: 3
      level: 1
      run: bash $route/.test/mock-review-clean.sh

judges:
  - rhx route.stone.judge --mechanism reviewed? --stone $stone --route $route --allow-blockers 1 --allow-nitpicks 5
