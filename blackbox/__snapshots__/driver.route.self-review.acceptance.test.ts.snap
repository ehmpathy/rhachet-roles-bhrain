exports[`driver.route.review.self.acceptance given: [case5] clone promises too quickly (time enforcement) when: [t1] second promise attempt (too quickly) then: stdout has good vibes 1`] = `
"рҹҰү the way speaks for itself

рҹҚӮ what is the rush?
   в”ңв”Җ ...
   в”Ӯ
   в”ңв”Җ what does haste cost?
   в”ңв”Җ ...
   в”Ӯ
   в”ңв”Җ does the self weigh more than the whole?
   в”Ӯ  в”ңв”Җ what you miss, they must find
