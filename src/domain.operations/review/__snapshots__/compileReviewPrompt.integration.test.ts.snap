--- a/src/cart/tax.ts
+++ b/src/cart/tax.ts
@@ -1,3 +1,4 @@
 export const applyTax = (price: number, rate: number): number => {
-  return price + price * rate;
+  const safeRate = Math.max(rate, 0);
+  return price + price * safeRate;
 };
</target.diff>

<target.file path="src/cart/tax.ts">
export const applyTax = (price: number, rate: number): number => {
  const safeRate = Math.max(rate, 0);
  return price + price * safeRate;
};
</target.file>

