   ├─ and finds these artifacts
   │  ├─ 1 file to review
   │  └─ [~] ./1.stone.i1.md   4 lines  +0 -0
   │
   └─ when ready, run
      └─ rhx route.stone.set --stone 1 --as approved
"
`;

