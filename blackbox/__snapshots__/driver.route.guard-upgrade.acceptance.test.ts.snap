exports[`driver.route.guard-upgrade.acceptance given: [case1] a route with mixed guards when: [t0] plan previews the whole route then: stdout matches snapshot 1`] = `
"
рџ¦‰ the way reveals itself, one stone at a time

рџ—ї route.guard.upgrade --mode plan
   в”њв”Ђ route = route
   в”‚
   в”њв”Ђ 1.vision.guard
   в”‚  в””в”Ђ decision = skipped, no provenance
   в”‚
   в”њв”Ђ 2.kept.guard
   в”‚  в”њв”Ђ decision = kept, no change
   в”‚  в””в”Ђ from = templates/2.kept.guard
   в”‚
   в”њв”Ђ 5.1.execution.guard
   в”‚  в”њв”Ђ decision = upgrade available
   в”‚  в”њв”Ђ from = templates/5.1.execution.guard
   в”‚  в””в”Ђ diff
   в”‚     в”њв”Ђ
   в”‚     в”‚
   в”‚     в”‚  -   - echo "reason: old frame"
   в”‚     в”‚  +   - echo "reason: new frame"
   в”‚     в”‚
   в”‚     в””в”Ђ
   в”‚
   в”њв”Ђ 5.10.other.guard
   в”‚  в”њв”Ђ decision = upgrade available
   в”‚  в”њв”Ђ from = templates/5.10.other.guard
   в”‚  в””в”Ђ diff
   в”‚     в”њв”Ђ
   в”‚     в”‚
   в”‚     в”‚  -   - echo "reason: old ten"
   в”‚     в”‚  +   - echo "reason: new ten"
   в”‚     в”‚
   в”‚     в””в”Ђ
   в”‚
   в”њв”Ђ 9.broken.guard
   в”‚  в””в”Ђ decision = absent source
   в”‚
   в”њв”Ђ summary = 2 available, 1 kept, 1 skipped, 1 absent
   в””в”Ђ вљ  1 guard blocked вЂ” a full apply is refused; scope a clean stone with --stone
"
`;

