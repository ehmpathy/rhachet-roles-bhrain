 export const freightFee = (weightKg: number): number => {
+  // free freight over 10kg, flat rate below
+  if (weightKg > 10) return 0;
   return weightKg * 5;
 };
</target.diff>

<target.file path="src/cart/freight.ts">
export const freightFee = (weightKg: number): number => {
  // free freight over 10kg, flat rate below
  if (weightKg > 10) return 0;
  return weightKg * 5;
};
</target.file>

---

<target.diff path="src/cart/price.ts">
diff --git a/src/cart/price.ts b/src/cart/price.ts
index 5eb85b7e9b0f81f6c85fbc5adaebbc7ba3b13ffc..aaee2209d73119bbce682d6a05286eca1312fcd1 100644
--- a/src/cart/price.ts
+++ b/src/cart/price.ts
@@ -1,3 +1,5 @@
 export const applyDiscount = (price: number, percent: number): number => {
-  return price - price * percent;
+  // clamp percent to [0, 1] so a bad input can never yield a negative price
+  const safePercent = Math.min(Math.max(percent, 0), 1);
+  return price - price * safePercent;
 };
</target.diff>

<target.file path="src/cart/price.ts">
export const applyDiscount = (price: number, percent: number): number => {
  // clamp percent to [0, 1] so a bad input can never yield a negative price
  const safePercent = Math.min(Math.max(percent, 0), 1);
  return price - price * safePercent;
};
</target.file>

---

