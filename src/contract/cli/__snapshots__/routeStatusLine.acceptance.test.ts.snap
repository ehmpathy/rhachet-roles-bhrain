exports[`routeStatusLine.acceptance given: [case13] a bound route whose phase derivation faults (degrade) when: [t0] the renderer runs with that cwd then: its stderr matches the phase-fault snapshot: route.status.line - phase.degrade.stderr 1`] = `"[route.status.line] fault: phase derivation faulted for stone "1.vision", degraded to plain stone line: SyntaxError: Expected property name or '}' in JSON at position 2 (line 1 column 3)"`;

exports[`routeStatusLine.acceptance given: [case14] a bound route with a driver-blocked guardless stone (yield phase) when: [t0] the renderer runs with that cwd then: its output matches the blocked-yield snapshot: route.status.line - blocked.yield 1`] = `
